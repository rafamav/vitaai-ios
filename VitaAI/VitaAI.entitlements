<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>aps-environment</key>
	<string>production</string>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!--
		CloudCar / CarPlay communication entitlement. Apple gates this behind
		manual approval through https://developer.apple.com/contact/carplay/.
		The key must remain present so debug builds can register a CarPlay
		scene against the CarPlay Simulator; production CarPlay activation
		will only work once Apple grants the entitlement on the App ID.
	-->
	<key>com.apple.developer.carplay-communication</key>
	<true/>
</dict>
</plist>

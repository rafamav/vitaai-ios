# Fastlane Environment Variables
# Copie para .env e preencha com seus valores

# Apple ID (App Store Connect)
APPLE_ID=seu-email@bymav.com

# Team ID (10 caracteres)
# Obter em: App Store Connect → Membership → Team ID
TEAM_ID=ABCDE12345

# App Store Connect Team ID (geralmente igual ao TEAM_ID)
ITC_TEAM_ID=ABCDE12345

# Match (certificados) - senha para desencriptar repositório
MATCH_PASSWORD=sua-senha-segura

# Match Keychain Password (para CI/CD)
MATCH_KEYCHAIN_PASSWORD=keychain-password

# App Store Connect API Key (RECOMENDADO - sem precisar de senha/2FA)
# Gerar em: App Store Connect → Users and Access → Keys → App Store Connect API
# ASC_KEY_ID=ABC123XYZ
# ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ASC_KEY_CONTENT=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Slack notifications (opcional)
# SLACK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
